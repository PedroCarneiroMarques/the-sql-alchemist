# Production environment template — copy to .env.production and inject real values
# via your secrets manager (Docker secrets, Kubernetes, GitHub Actions, etc.).
# Never commit .env.production with real secrets.

APP_ENV=production

DATA_PATH=data/flights.csv
OLLAMA_HOST=https://ollama.internal.example.com
OLLAMA_TIMEOUT=180

# Optional — only if your Ollama endpoint requires authentication
OLLAMA_API_KEY=

DEFAULT_MODEL_CHAIN=mistral:7b,phi4:14b,qwen2.5-coder:14b
DEFAULT_MODEL_PROFILE=balanced
MODEL_PROFILE_FAST=mistral:7b
MODEL_PROFILE_ACCURATE=deepseek-r1:8b,qwen3.6:35b-a3b

DEFAULT_WATCHDOG_SENSITIVITY=normal
DEFAULT_DELAY_COST_PER_MINUTE=50
DEFAULT_CANCELLATION_COST=200

LOG_LEVEL=INFO
LOG_TO_FILE=true
UI_LOCALE=en

# Set to true after production secrets are injected (see docs/DEPLOYMENT.md)
DEPLOYMENT_SECRETS_READY=true
