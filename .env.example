# Copy to .env and adjust for your local environment.
# config.py reads these variables automatically.

DATA_PATH=data/flights.csv
OLLAMA_HOST=http://localhost:11434
OLLAMA_TIMEOUT=180
DEFAULT_MODEL_CHAIN=mistral:7b,phi4:14b,qwen2.5-coder:14b,gemma4:26b,qwen3.6:27b,qwen3.6:35b-a3b,deepseek-r1:8b
DEFAULT_MODEL_PROFILE=balanced
MODEL_PROFILE_FAST=mistral:7b
MODEL_PROFILE_ACCURATE=deepseek-r1:8b,qwen3.6:35b-a3b,qwen3.6:27b,qwen2.5-coder:14b,phi4:14b
DEFAULT_WATCHDOG_SENSITIVITY=normal
LOG_LEVEL=INFO
LOG_TO_FILE=true
DEFAULT_DELAY_COST_PER_MINUTE=50
DEFAULT_CANCELLATION_COST=200
